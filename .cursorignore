# =============================================================================
# Cursor Ignore Rules – Local Python EMR
# Prevent AI indexing of patient data, exports, and generated documents
# =============================================================================


# ---------------------------------------------------------------------
# Patient data folders
# ---------------------------------------------------------------------
patients/
idClients/
records/
exports/
vault/
backups/
uploads/
db/


# ---------------------------------------------------------------------
# Generated documents and large data files
# ---------------------------------------------------------------------
*.pdf
*.csv
*.xlsx
*.log


# ---------------------------------------------------------------------
# Python cache / build artifacts
# ---------------------------------------------------------------------
__pycache__/
*.pyc
.ruff_cache/


# ---------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------
.venv/
venv/


# ---------------------------------------------------------------------
# Environment variables / secrets
# ---------------------------------------------------------------------
.env
.env.*


# ---------------------------------------------------------------------
# NOTE
# ---------------------------------------------------------------------
# We intentionally DO NOT ignore *.json because the project contains
# template JSON files such as:
#   templates/*.json
#   alerts_dashboard.json
# These should remain readable by Cursor.